---
config:
  theme: base
  themeVariables:
    fontSize: 26px
    fontFamily: "Inter, Segoe UI, system-ui, sans-serif"
    primaryColor: "#ffffff"
    lineColor: "#94a3b8"
    edgeLabelBackground: "#ffffff"
  flowchart:
    padding: 60
    nodeSpacing: 20
    rankSpacing: 35
    htmlLabels: true
    curve: basis
---
graph LR
    subgraph S1[" DL "]
        direction TB
        DL["Raw Datasets<br/>swiss-ai/multimodal-data"]
    end

    subgraph S2[" VAD "]
        direction TB
        VAD["Silero VAD"] --> MERGE["Merge + Pack"] --> LANGFILT["Lang Filter"]
    end

    subgraph S3[" To Shar "]
        direction TB
        TAR["WebDataset"] & ARROW["HF Arrow"] & RECIPE["Recipe"] & AUDIODIR["Audio Dir"] & PQ_IN["Parquet"] --> SHAR[("Shar")]
    end

    subgraph S4[" Tokenize "]
        direction TB
        ENTRY["tokenize.py"] --> MODE{{"Mode"}}
        MODE -- "audio_only" --> BIN_AO["audio .bin/.idx"]
        MODE -- "direct" --> BIN_ATD["direct .bin/.idx"]
        MODE -- "interleaved" --> PQ_CACHE[("Parquet Cache")]
    end

    subgraph S5[" Compose "]
        direction TB
        SORT["Sort → Detect runs → Chunk"]
        SORT --> APPLY["Apply pattern<br/>A → audio, T → text"]
        APPLY --> WRITE["pattern .bin/.idx"]
        SORT --> REM{"Remainder?"}
        REM -- "2+" --> WRITE_C["sub-pattern .bin/.idx"]
        REM -- "1" --> WRITE_T["transcribe .bin/.idx"]
    end

    DL --> S2 --> S3
    DL --> S3
    SHAR --> ENTRY
    PQ_CACHE --> SORT
    BIN_AO & BIN_ATD & WRITE & WRITE_C & WRITE_T --> TRAIN(["Megatron-LM Training"])

    classDef blue fill:#eef4fb,stroke:#7baed4,stroke-width:1.6px,color:#1a3a5c
    classDef red fill:#fef2f2,stroke:#e8a0a0,stroke-width:1.6px,color:#6b1a1a
    classDef amber fill:#fefaee,stroke:#dcc070,stroke-width:1.6px,color:#6b4a0a
    classDef purple fill:#f8f0ff,stroke:#c4a0e0,stroke-width:1.6px,color:#4a1a6b
    classDef store fill:#fefce8,stroke:#d4c040,stroke-width:1.6px,color:#6b5c00
    classDef output fill:#e8fdf0,stroke:#50c890,stroke-width:1.6px,color:#0a5a3a
    classDef train fill:#e0faf0,stroke:#34d399,stroke-width:2.4px,color:#065f46
    classDef compose fill:#f0f7ff,stroke:#7baed4,stroke-width:1.6px,color:#1a3a5c
    classDef decision fill:#faf5ff,stroke:#c4a0e0,stroke-width:1.6px,color:#4a1a6b

    class DL blue
    class VAD,MERGE,LANGFILT red
    class TAR,ARROW,RECIPE,AUDIODIR,PQ_IN amber
    class SHAR,PQ_CACHE store
    class ENTRY,MODE purple
    class BIN_AO,BIN_ATD output
    class SORT,APPLY compose
    class WRITE,WRITE_C,WRITE_T output
    class REM decision
    class TRAIN train

    style S1 fill:#eef4fb,stroke:#7baed4,stroke-width:1.6px
    style S2 fill:#fef2f2,stroke:#e8a0a0,stroke-width:1.6px
    style S3 fill:#fefaee,stroke:#dcc070,stroke-width:1.6px
    style S4 fill:#f8f0ff,stroke:#c4a0e0,stroke-width:1.6px
    style S5 fill:#eefdf2,stroke:#80ccaa,stroke-width:1.6px
